<h1><%= @hospital.name %></h1>

<p><strong>City:</strong> <%= @hospital.city %></p>
<p><strong>Address:</strong> <%= @hospital.address %></p>
<p><strong>Phone:</strong> <%= @hospital.phone %></p>

<hr>

<h2>Departments</h2>
<ul>
  <% @hospital.departments.each do |dept| %>
    <li><%= dept.name %></li>
  <% end %>
</ul>

<h2>Doctors</h2>
<ul>
  <% @hospital.doctors.each do |doc| %>
    <li>
      <%= doc.name %> — <%= doc.specialty %>
    </li>
  <% end %>
</ul>

<h2>Reviews</h2>
<ul>
  <% @hospital.reviews.each do |review| %>
    <li>
      ⭐ <%= review.rating %> — <%= review.comment %>
    </li>
  <% end %>
</ul>

<h2>Location</h2>

<iframe
  width="100%"
  height="400"
  style="border:0"
  loading="lazy"
  allowfullscreen
  src="https://maps.google.com/maps?q=<%= @hospital.latitude %>,<%= @hospital.longitude %>&z=15&output=embed">
</iframe>

<p>
  <%= link_to "Back to Hospitals", hospitals_path %>
</p>
